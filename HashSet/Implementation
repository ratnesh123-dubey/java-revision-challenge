import java.util.HashSet;

public class Main {
    public static void main(String[] args) {

        HashSet<String> set = new HashSet<>();

        set.add("A");
        set.add("B");
        set.add("C");
        set.add("A"); // duplicate ignore

        System.out.println(set);

        System.out.println(set.contains("B")); // true

        set.remove("B");

        System.out.println(set);
    }
}
